# Overseerr/Jellyseerr base API URL
SEERR_URL=http://<YOUR_SERVER_IP>:5055/api/v1

# Overseerr/Jellyseerr API key (Settings → General → API Key)
SEERR_API_KEY=

# Shared secret for the /webhook endpoint (set the same value in Seerr's webhook notification settings)
WEBHOOK_AUTH_HEADER=

# Bearer token for the /requests endpoint (used by Glance to authenticate)
REQUESTS_AUTH_TOKEN=

# Timezone
TZ=America/Toronto

# Go memory limit for the container
GOMEMLIMIT=4MiB
